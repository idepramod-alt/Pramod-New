<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D0D0D" android:padding="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="12dp">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="←" android:textColor="#FFFFFF" android:background="#222222" android:paddingStart="12dp" android:paddingEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="📊 Audio Analysis" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:paddingStart="10dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <TextView android:id="@+id/tvFileName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="No file selected" android:textColor="#AAAAAA" android:textSize="12sp" android:padding="10dp" android:background="#1A1A1A"/>
        <Button android:id="@+id/btnPickFile" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📂" android:textColor="#FFFFFF" android:background="#333333" android:layout_marginStart="6dp"/>
    </LinearLayout>

    <Button android:id="@+id/btnAnalyze" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📊 Analyze File" android:textColor="#FFFFFF" android:background="#2E7D32" android:layout_marginBottom="10dp"/>

    <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Select a WAV file and tap Analyze" android:textColor="#888888" android:textSize="12sp" android:padding="8dp" android:layout_marginBottom="6dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/tvResult" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#CCCCCC" android:textSize="13sp"
            android:background="#111111" android:padding="14dp" android:fontFamily="monospace"/>
    </ScrollView>
</LinearLayout>
