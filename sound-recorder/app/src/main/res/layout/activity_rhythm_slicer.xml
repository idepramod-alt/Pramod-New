<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#1A1A1A" android:paddingStart="8dp">
        <Button android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="←" android:textSize="18sp" android:textColor="#FFFFFF"
            android:background="@null" android:padding="0dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🎯 AI Rhythm Slicer"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Selected file -->
            <TextView android:id="@+id/tvSelectedFile"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="📂 No file selected" android:textColor="#BBBBBB"
                android:textSize="13sp" android:padding="10dp" android:background="#1E1E1E"
                android:layout_marginBottom="8dp"/>

            <!-- Pick + Detect -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnPickFile"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="📂 Pick WAV" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:background="#333333" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnDetect"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="🎯 Detect Slices" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:background="#E65100"/>
            </LinearLayout>

            <!-- Detection settings label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="DETECTION SETTINGS" android:textColor="#FF6D00"
                android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

            <!-- Sensitivity -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                    android:text="Sensitivity" android:textColor="#AAAAAA" android:textSize="13sp"/>
                <SeekBar android:id="@+id/sbSensitivity"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <TextView android:id="@+id/tvSensVal"
                    android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="0.50" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Pre-roll -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                    android:text="Pre-roll" android:textColor="#AAAAAA" android:textSize="13sp"/>
                <SeekBar android:id="@+id/sbPreRoll"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <TextView android:id="@+id/tvPreRollVal"
                    android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="5 ms" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Post-roll -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                    android:text="Post-roll" android:textColor="#AAAAAA" android:textSize="13sp"/>
                <SeekBar android:id="@+id/sbPostRoll"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <TextView android:id="@+id/tvPostRollVal"
                    android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="80 ms" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Min gap -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                    android:text="Min Gap" android:textColor="#AAAAAA" android:textSize="13sp"/>
                <SeekBar android:id="@+id/sbMinGap"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                <TextView android:id="@+id/tvMinGapVal"
                    android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="50 ms" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Status -->
            <TextView android:id="@+id/tvStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Pick a WAV file and tap Detect Slices"
                android:textColor="#4CAF50" android:textSize="13sp"
                android:padding="10dp" android:background="#1A2A1A" android:layout_marginBottom="6dp"/>

            <!-- Summary (BPM + counts) -->
            <TextView android:id="@+id/tvSummary"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#FF8F00" android:textSize="12sp"
                android:padding="8dp" android:background="#1E1A00"
                android:layout_marginBottom="10dp" android:visibility="gone"/>

            <!-- Export label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="EXPORT &amp; KIT" android:textColor="#FF6D00"
                android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

            <!-- Row 1: Export All + Build Kit -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnExportAll"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="💾 Export All" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:background="#1B5E20" android:layout_marginEnd="6dp" android:enabled="false"/>
                <Button android:id="@+id/btnBuildKit"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="🥁 Octapad Kit" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:background="#4A148C" android:enabled="false"/>
            </LinearLayout>

            <!-- Row 2: Share ZIP + Save to Music -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnShareKit"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="📤 Share ZIP" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:background="#0277BD" android:layout_marginEnd="6dp" android:enabled="false"/>
                <Button android:id="@+id/btnSaveDownloads"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="⬇️ Save Music" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:background="#00695C" android:enabled="false"/>
            </LinearLayout>

            <!-- Batch prepare -->
            <Button android:id="@+id/btnBatchPrep"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="⚙️ Batch Prepare (44100Hz / Mono / Normalize)"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:background="#BF360C" android:layout_marginBottom="12dp" android:enabled="false"/>

            <!-- Slice list label -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="DETECTED SLICES  (tap to preview in editor)"
                android:textColor="#FF6D00" android:textSize="11sp"
                android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

            <ListView android:id="@+id/lvSlices"
                android:layout_width="match_parent" android:layout_height="240dp"
                android:background="#1A1A1A" android:divider="#2A2A2A" android:dividerHeight="1dp"/>

            <!-- Log -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="LOG" android:textColor="#555555" android:textSize="11sp"
                android:layout_marginTop="12dp" android:layout_marginBottom="4dp"/>

            <ScrollView android:id="@+id/scrollLog"
                android:layout_width="match_parent" android:layout_height="160dp"
                android:background="#0D0D0D">
                <TextView android:id="@+id/tvLog"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#888888" android:textSize="11sp"
                    android:fontFamily="monospace" android:padding="8dp"/>
            </ScrollView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
