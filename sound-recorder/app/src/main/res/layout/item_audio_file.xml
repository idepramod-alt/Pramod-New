<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="6dp"
    android:padding="14dp">

    <!-- Row 1: Icon + Name + Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎵"
            android:textSize="22sp"
            android:paddingEnd="10dp"/>

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="filename.wav"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="middle"/>

        <TextView
            android:id="@+id/tvFormatBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WAV"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@color/accent_red"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>
    </LinearLayout>

    <!-- Row 2: Info -->
    <TextView
        android:id="@+id/tvFileInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2.78s  •  244 KB"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingBottom="10dp"/>

    <!-- Row 3: Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="✂️ Edit"
            android:textColor="@color/text_primary"
            android:background="@color/bg_card2"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnConvert"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🔄 Convert"
            android:textColor="@color/text_primary"
            android:background="@color/bg_card2"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnOctapad"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="📤 Octapad"
            android:textColor="@color/text_primary"
            android:background="@color/accent_green"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🗑"
            android:textColor="@color/text_primary"
            android:background="@color/bg_card2"
            android:textSize="13sp"
            android:padding="0dp"/>
    </LinearLayout>

</LinearLayout>
