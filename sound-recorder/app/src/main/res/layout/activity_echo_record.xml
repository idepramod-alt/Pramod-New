<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">

    <!-- Title bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#1A1A1A" android:paddingStart="8dp">
        <Button android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="←" android:textSize="18sp" android:textColor="#FFFFFF"
            android:background="@null" android:padding="0dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🎙️ Recorder"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- USB status -->
            <TextView android:id="@+id/tvUsbStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="⚪ No USB Device (Built-in Mic)"
                android:textColor="#888888" android:textSize="13sp" android:layout_marginBottom="12dp"/>

            <!-- Waveform -->
            <com.pramod.soundstudio.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent" android:layout_height="100dp"
                android:background="#0D0D0D" android:layout_marginBottom="16dp"/>

            <!-- Timer -->
            <TextView android:id="@+id/tvTimer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="00:00.000" android:textColor="#FFFFFF" android:textSize="36sp"
                android:textStyle="bold" android:gravity="center" android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <!-- Status -->
            <TextView android:id="@+id/tvStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Ready to record" android:textColor="#888888"
                android:textSize="14sp" android:gravity="center" android:layout_marginBottom="12dp"/>

            <!-- Echo preview text -->
            <TextView android:id="@+id/tvEchoPreview"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#FF8F00" android:textSize="12sp"
                android:padding="8dp" android:background="#1E1A00" android:layout_marginBottom="12dp"/>

            <!-- Echo toggle row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="12dp" android:background="#1A1A1A" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Echo Mode"
                    android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                <Switch android:id="@+id/swEcho"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <!-- Echo controls -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#161616"
                android:padding="12dp" android:layout_marginBottom="16dp">

                <!-- Delay -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/tvLabelDelay"
                        android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Delay" android:textColor="#AAAAAA" android:textSize="13sp"/>
                    <SeekBar android:id="@+id/sbDelay"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvDelayVal"
                        android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="250 ms" android:textColor="#FFFFFF" android:textSize="12sp" android:gravity="end"/>
                </LinearLayout>

                <!-- Feedback -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/tvLabelFeedback"
                        android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Feedback" android:textColor="#AAAAAA" android:textSize="13sp"/>
                    <SeekBar android:id="@+id/sbFeedback"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvFeedbackVal"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="35%" android:textColor="#FFFFFF" android:textSize="12sp" android:gravity="end"/>
                </LinearLayout>

                <!-- Dry -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/tvLabelDry"
                        android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Dry Mix" android:textColor="#AAAAAA" android:textSize="13sp"/>
                    <SeekBar android:id="@+id/sbDry"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvDryVal"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="70%" android:textColor="#FFFFFF" android:textSize="12sp" android:gravity="end"/>
                </LinearLayout>

                <!-- Wet -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvLabelWet"
                        android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Wet Mix" android:textColor="#AAAAAA" android:textSize="13sp"/>
                    <SeekBar android:id="@+id/sbWet"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvWetVal"
                        android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="40%" android:textColor="#FFFFFF" android:textSize="12sp" android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Record button -->
            <Button android:id="@+id/btnRecord"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:text="⏺ RECORD" android:textColor="#FFFFFF"
                android:textSize="18sp" android:textStyle="bold" android:background="#E53935"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
