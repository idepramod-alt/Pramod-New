<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core permissions (existing) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Background recording service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires type-specific foreground service permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- OTG USB Host support (existing) -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SoundStudio">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- NEW: Dashboard (replaces FilesActivity as launcher)        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <activity
            android:name=".DashboardActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- EXISTING activities (unchanged, still accessible)          -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- File Manager Screen (accessible from Dashboard) -->
        <activity
            android:name=".FilesActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- Record Screen -->
        <activity
            android:name=".RecordActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Trim / Edit Screen -->
        <activity
            android:name=".EditorActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- NEW: Professional Module Activities                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- Editor Launcher (file picker → EditorActivity) -->
        <activity
            android:name=".EditorLauncherActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Ultra Precision Auto-Trim -->
        <activity
            android:name=".AutoTrimActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- AI Drum Sample Splitter -->
        <activity
            android:name=".DrumSplitterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Vocal Remover / Stem Separation -->
        <activity
            android:name=".VocalRemoverActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Audio Enhancement (EQ, Compressor, Noise Reduction) -->
        <activity
            android:name=".EnhancementActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Audio Analysis (BPM, LUFS, Spectrum) -->
        <activity
            android:name=".AnalysisActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Audio Effects (Reverb, Delay, Chorus, Pitch) -->
        <activity
            android:name=".EffectsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Format Converter -->
        <activity
            android:name=".ConverterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Batch Processor -->
        <activity
            android:name=".BatchActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Octapad Tools -->
        <activity
            android:name=".OctapadToolsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Settings -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- NEW: Background Recording Service                          -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <service
            android:name=".RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- FileProvider for sharing audio files (existing, unchanged) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.pramod.soundstudio.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
