<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ff111111"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Top Control Bar ── -->
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#ff000000"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <Button android:textSize="12sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnBack" android:background="@drawable/btn_3d_red"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:text="BACK" android:layout_weight="0.8"/>
        <Button android:textSize="18sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnPrevLoop" android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="-" android:layout_weight="0.6"/>
        <TextView android:textSize="14sp" android:textStyle="bold" android:textColor="#ffffff00"
            android:gravity="center" android:id="@+id/txtLoopChannel"
            android:background="#ff111111" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_marginLeft="2dp"
            android:text="LOOP 1" android:layout_weight="1.4"/>
        <Button android:textSize="18sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnNextLoop" android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="+" android:layout_weight="0.6"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnEditLoops" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="EDIT" android:layout_weight="1"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnRenameLoop" android:background="@drawable/btn_3d_purple"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="NAME" android:layout_weight="1"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnAdvancedLoops" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="ADV" android:layout_weight="1"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnSaveLoop" android:background="@drawable/btn_glossy_3d"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="SAVE" android:layout_weight="1"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnLoadLoop" android:background="@drawable/btn_3d_orange"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="LOAD" android:layout_weight="1"/>
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:background="@drawable/btn_3d_red"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="2dp" android:text="STOP" android:layout_weight="1"
            android:onClick="onStopLoopClick"/>
    </LinearLayout>

    <!-- ── Mode Bar: Loop Mode / Drum Mode + ADD + REC ── -->
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#ff1a1a2e"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="3dp">

        <Button android:textSize="11sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnLoopMode" android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:text="🔁 LOOP" android:layout_weight="1.1"/>
        <Button android:textSize="11sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnDrumMode" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🥁 DRUM" android:layout_weight="1.1"/>

        <View android:background="#ff444444" android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>

        <!-- ADD button: load audio into selected pad directly -->
        <Button android:textSize="11sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnAddLoop" android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:text="➕ ADD" android:layout_weight="1"/>

        <!-- REC button: opens multi-track recording dialog -->
        <Button android:textSize="11sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnRec" android:background="#ffcc0000"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🔴 REC" android:layout_weight="1"/>

        <!-- Velocity Sensitivity toggle: ON = MIDI velocity scales volume, OFF = fixed volume -->
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnVelocity" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🎚️VEL\nOFF" android:layout_weight="1"/>

        <!-- MIDI Key Mapping: manual ON/OFF + per-pad note assignment dialog -->
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnMidiMap" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🎹MAP\nOFF" android:layout_weight="1"/>

        <!-- Loop Sync panel toggle button -->
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnLoopSync" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🔄SYNC\nOFF" android:layout_weight="1"/>

        <!-- Tempo Sync: ON = all kits share one BPM+Pitch; OFF = per-kit BPM+Pitch -->
        <Button android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnTempoSync" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="⏱TEMPO&#10;SYNC OFF" android:layout_weight="1"/>

        <!-- Brand name: no plate, just bold yellow text with a black stroke -->
        <TextView android:id="@+id/txtBrandName"
            android:textSize="9sp" android:textStyle="bold" android:textColor="#ffffff00"
            android:shadowColor="#ff000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="2.5"
            android:gravity="center" android:singleLine="true"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="PRAMOD OCTAPAD LOOPS" android:layout_weight="1.6"/>

        <View android:background="#ff444444" android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>

        <TextView android:textSize="10sp" android:textColor="#ffffffff"
            android:gravity="center" android:id="@+id/txtLoopStatus"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:text="TAP A PAD TO PLAY/STOP" android:layout_weight="2"/>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="#ff00ff00"
            android:gravity="center" android:id="@+id/txtMidiStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp" android:text="MIDI: off"/>

        <!-- MIDI Connect/Disconnect toggle — tap to connect or disconnect Roland SPD-20 Pro -->
        <Button android:textSize="9sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnMidiConnect" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="6dp" android:text="🔌MIDI&#10;OFF" android:layout_weight="1.1"/>
        <!-- CC Controls: assign any Roland SPD-20 Pro button → Vol/Tempo/Pitch/Stop via LEARN -->
        <Button android:textSize="9sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnCCCtrl" android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_marginLeft="4dp" android:text="🎛️CC&#10;CTRL" android:layout_weight="1.1"/>
    </LinearLayout>

    <!-- ── Advanced Panel (ADV button toggles visibility) ── -->
    <!-- Weighted (not fixed-height) ScrollView: shares the remaining vertical
         space 50/50 with the pad grid below (loopPadArea also has weight=1),
         so the pads always stay visible at roughly half the screen while ADV
         is open — you can tweak a control and tap a pad to hear the effect
         instantly instead of the panel eating the pads' space. Extra FX rows
         that don't fit in that half just scroll inside this box. -->
    <ScrollView android:id="@+id/advancedControlPanelScroll"
        android:visibility="gone" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginBottom="4dp"
        android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:id="@+id/advancedControlPanel"
        android:background="#ff333333" android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Master Volume row -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/txtMasterVolLabel"
                android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:layout_width="62dp" android:layout_height="wrap_content"
                android:text="MASTER VOL"/>
            <SeekBar android:id="@+id/seekMasterVolume"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:max="100" android:progress="100" android:layout_weight="1"/>
            <TextView android:textSize="12sp" android:textColor="#ff00afff"
                android:gravity="end" android:id="@+id/txtMasterVolVal"
                android:layout_width="40dp" android:layout_height="wrap_content"
                android:text="100%"/>
            <Button android:id="@+id/btnMasterVolMode"
                android:textSize="9sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:background="@drawable/btn_3d_blue"
                android:layout_width="44dp" android:layout_height="32dp"
                android:layout_marginStart="4dp" android:text="ALL"/>
        </LinearLayout>

        <!-- Playback mode row -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <CheckBox android:textSize="12sp" android:textColor="#ffffffff"
                android:id="@+id/chkMultiMode" android:layout_width="0dp"
                android:layout_height="wrap_content" android:text="MULTI-PLAY"
                android:layout_weight="1" android:buttonTint="#ff00afff"/>
            <CheckBox android:textSize="12sp" android:textColor="#ffffffff"
                android:id="@+id/chkOneShotMode" android:layout_width="0dp"
                android:layout_height="wrap_content" android:text="ONE-SHOT"
                android:layout_weight="1" android:buttonTint="#ff00afff"/>
        </LinearLayout>

        <!-- Drum-mode-only FX (per pad — same as MainActivity's per-pad
             chkDelay/seekDelayTime/seekDelayLevel/seekChokeGroup, just scoped to
             whichever pad is selected here). Only affects real DRUM MODE hits;
             Loop mode and One-Shot mode keep their own existing, untouched behavior. -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView android:textSize="9sp" android:textStyle="bold" android:textColor="#ff888888"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CHOKE GRP"/>
            <SeekBar android:id="@+id/seekDrumChoke"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:max="4" android:progress="0" android:layout_weight="1"
                android:layout_marginStart="4dp"/>
            <TextView android:textSize="10sp" android:textColor="#ff00afff" android:gravity="end"
                android:id="@+id/txtDrumChokeVal" android:layout_width="16dp"
                android:layout_height="wrap_content" android:text="0"/>
        </LinearLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp">
            <CheckBox android:textSize="11sp" android:textColor="#ff00ffff"
                android:id="@+id/chkDrumDelay" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="DLY" android:buttonTint="#ff00ffff"/>
            <TextView android:textSize="9sp" android:textColor="#ff888888"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp" android:text="TIME"/>
            <SeekBar android:id="@+id/seekDrumDelayTime"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:max="500" android:progress="150" android:layout_weight="1"
                android:layout_marginStart="4dp"/>
            <TextView android:textSize="9sp" android:textColor="#888888"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp" android:text="LVL"/>
            <SeekBar android:id="@+id/seekDrumDelayLevel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:max="100" android:progress="50" android:layout_weight="1"
                android:layout_marginStart="4dp"/>
            <TextView android:textSize="10sp" android:textColor="#ff00afff" android:gravity="end"
                android:id="@+id/txtDrumDelayVal" android:layout_width="32dp"
                android:layout_height="wrap_content" android:text="50%"/>
        </LinearLayout>

        <!-- Account / Cloud sync row -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:layout_marginBottom="2dp">
            <TextView
                android:id="@+id/txtSignedInAs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="#ff00afff"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""/>
            <Button
                android:id="@+id/btnSignOut"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Sign Out"
                android:textSize="9sp"
                android:textColor="#ffffffff"
                android:background="@drawable/btn_3d_dark"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
        </LinearLayout>

        <!-- EQ row -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HI"/>
            <SeekBar android:tag="seekEqHi" android:layout_width="0dp"
                android:layout_height="wrap_content" android:max="100" android:progress="50"
                android:layout_weight="1"/>
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginLeft="4dp" android:text="MID"/>
            <SeekBar android:tag="seekEqMid" android:layout_width="0dp"
                android:layout_height="wrap_content" android:max="100" android:progress="50"
                android:layout_weight="1"/>
            <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginLeft="4dp" android:text="LOW"/>
            <SeekBar android:tag="seekEqLow" android:layout_width="0dp"
                android:layout_height="wrap_content" android:max="100" android:progress="50"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>

    <!-- ── Speed / Pitch / BPM bar ── -->
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
        android:background="#ff222222" android:padding="4dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BPM:" android:layout_marginEnd="4dp"/>
        <EditText android:textSize="10sp" android:textColor="#ffffffff"
            android:textColorHint="#ff888888" android:gravity="center"
            android:id="@+id/editCustomBpm" android:background="#ff444444"
            android:padding="2dp" android:layout_width="40dp" android:layout_height="30dp"
            android:hint="120" android:inputType="numberDecimal"/>
        <Button android:textSize="8sp" android:textColor="#ffffffff"
            android:id="@+id/btnSetBpm" android:background="@drawable/btn_3d_dark"
            android:layout_width="35dp" android:layout_height="30dp"
            android:text="SET" android:layout_marginStart="2dp"/>
        <View android:background="#ff555555" android:layout_width="1dp"
            android:layout_height="20dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
        <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SPEED:"/>
        <Button android:textColor="#ffffffff" android:id="@+id/btnTempoMinus"
            android:background="@drawable/btn_3d_dark" android:layout_width="30dp"
            android:layout_height="30dp" android:text="-" android:layout_marginStart="2dp"/>
        <SeekBar android:id="@+id/seekTempo" android:layout_width="0dp"
            android:layout_height="wrap_content" android:max="200" android:progress="100"
            android:layout_weight="1"/>
        <Button android:textColor="#ffffffff" android:id="@+id/btnTempoPlus"
            android:background="@drawable/btn_3d_dark" android:layout_width="30dp"
            android:layout_height="30dp" android:text="+"/>
        <TextView android:textSize="10sp" android:textColor="#ff00afff" android:gravity="end"
            android:id="@+id/txtTempoVal" android:layout_width="30dp"
            android:layout_height="wrap_content" android:text="1.0x"/>
        <View android:background="#ff555555" android:layout_width="1dp"
            android:layout_height="20dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
        <Button android:textColor="#ffffffff" android:background="@drawable/btn_3d_dark"
            android:layout_width="30dp" android:layout_height="30dp"
            android:text="-" android:onClick="onScaleMinus"/>
        <TextView android:textSize="12sp" android:textStyle="bold" android:textColor="#ff00afff"
            android:gravity="center" android:tag="txtScaleDisplay"
            android:layout_width="30dp" android:layout_height="wrap_content" android:text="C"/>
        <Button android:textColor="#ffffffff" android:background="@drawable/btn_3d_dark"
            android:layout_width="30dp" android:layout_height="30dp"
            android:text="+" android:onClick="onScalePlus"/>
        <View android:background="#ff555555" android:layout_width="1dp"
            android:layout_height="20dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
        <TextView android:textSize="10sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PTCH:"/>
        <SeekBar android:id="@+id/seekPitch" android:layout_width="0dp"
            android:layout_height="wrap_content" android:max="200" android:progress="100"
            android:layout_weight="1"/>
        <TextView android:textSize="10sp" android:textColor="#ff00afff" android:gravity="end"
            android:id="@+id/txtPitchVal" android:layout_width="30dp"
            android:layout_height="wrap_content" android:text="1.0x"/>
        <View android:background="#ff555555" android:layout_width="1dp"
            android:layout_height="20dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
        <Button android:textSize="8sp" android:textStyle="bold" android:textColor="#ffffffff"
            android:id="@+id/btnResetSpeedPitch" android:background="@drawable/btn_3d_dark"
            android:layout_width="40dp" android:layout_height="30dp" android:text="RESET"/>
    </LinearLayout>

    <!-- ── REC Panel (REC button toggles visibility, same pattern as ADV) ── -->
    <!-- Shares vertical space 50/50 with loopPadArea below via weight=1 so
         the real pads always stay visible at the bottom while the panel is open. -->
    <ScrollView android:id="@+id/recControlPanelScroll"
        android:visibility="gone" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginBottom="4dp"
        android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:id="@+id/recControlPanel"
        android:background="#ff1a1a2e" android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    </LinearLayout>
    </ScrollView>

    <!-- ── Loop Sync Panel (🔄SYNC button toggles visibility, same pattern as ADV/REC) ── -->
    <!-- weight=1 → shares screen 50/50 with pad grid, pads always visible below -->
    <ScrollView android:id="@+id/loopSyncPanelScroll"
        android:visibility="gone" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginBottom="4dp"
        android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:id="@+id/loopSyncPanel"
        android:background="#ff0d1f0d" android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header row -->
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView android:textSize="13sp" android:textStyle="bold"
                android:textColor="#ff00ffcc"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔄 LOOP SYNC"/>
            <Button android:id="@+id/btnSyncAll"
                android:textSize="11sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:background="@drawable/btn_3d_blue"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:text="⚡ SYNC ALL"/>
        </LinearLayout>

        <!-- Hint text -->
        <TextView android:textSize="9sp" android:textColor="#ff666666"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="SYNC ALL = sab playing loops ek saath restart  |  ◀ = peeche shift  ▶ = aage shift  ↺ = sirf yeh pad restart"/>

        <!-- Per-pad nudge rows + nudge step selector — built in Java (onCreate) -->
        <LinearLayout android:id="@+id/loopSyncPadContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
    </ScrollView>

    <!-- ── Pad Grid ── -->
    <!-- Hidden stubs: workflow CI patch scripts grep for these IDs to skip re-adding their rows -->
    <Button android:id="@+id/btnRecordStart" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
    <Button android:id="@+id/btnRecordStop"  android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
    <LinearLayout android:orientation="vertical" android:id="@+id/loopPadArea"
        android:padding="2dp" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="1">
            <Button android:textSize="18sp" android:textStyle="bold" android:textColor="#ffffffff"
                android:id="@+id/loopPad1" android:background="@drawable/pad_black_selector"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="4dp" android:text="PAD 1" android:layout_weight="1"/>
