<?xml version="1.0" encoding="utf-8"?>
<!-- Static (non-pressable) 3D glossy black plaque used behind the brand name label. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="3dp" android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <solid android:color="#77000000"/>
        </shape>
    </item>
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <gradient android:startColor="#ff444444" android:endColor="#ff000000" android:angle="270"/>
            <stroke android:width="1dp" android:color="#ccffffff"/>
            <padding android:left="4dp" android:top="2dp" android:right="4dp" android:bottom="2dp"/>
        </shape>
    </item>
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <gradient android:startColor="#88ffffff" android:endColor="#00ffffff" android:angle="270" android:centerY="0.3" android:centerColor="#22ffffff"/>
        </shape>
    </item>
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <gradient android:startColor="#00000000" android:endColor="#aa000000" android:angle="270" android:centerY="0.7"/>
        </shape>
    </item>
</layer-list>
