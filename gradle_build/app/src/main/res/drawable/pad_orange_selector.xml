<?xml version="1.0" encoding="utf-8"?>
<!-- Pad idle in DRUM mode — orange border indicates one-shot trigger mode -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient android:startColor="#ff331400" android:endColor="#ff220e00" android:angle="270" android:centerColor="#ff221000"/>
                    <stroke android:width="3dp" android:color="#ffff9933"/>
                    <padding android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:left="6dp" android:top="6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <solid android:color="#99200800"/>
                </shape>
            </item>
            <item android:right="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient android:startColor="#ff442200" android:endColor="#ff1a0a00" android:angle="270" android:centerColor="#ff2a1000"/>
                    <stroke android:width="2dp" android:color="#ffcc6600"/>
                    <padding android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp"/>
                </shape>
            </item>
            <item android:right="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient android:startColor="#44ffffff" android:endColor="#00ffffff" android:angle="270" android:centerY="0.3" android:centerColor="#11ffffff"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
